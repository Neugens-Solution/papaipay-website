# Google Sheets is the primary record for all public website form submissions.
# Keep these values server-side only. Do not expose them with NEXT_PUBLIC_.
GOOGLE_SHEETS_WEB_APP_URL=
GOOGLE_SHEETS_FORM_SECRET=

# Monday.com remains a secondary workflow copy during the transition.
# Keep these values server-side only. Do not expose them with NEXT_PUBLIC_.
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=

# Optional Monday.com column IDs used to map submitted fields.
# Leave blank to skip a column; item creation still works with the item name.
MONDAY_NAME_COLUMN_ID=
MONDAY_EMAIL_COLUMN_ID=
# MONDAY_PHONE_COLUMN_ID should point to a Monday.com text column (not a phone column).
MONDAY_PHONE_COLUMN_ID=
MONDAY_COMPANY_COLUMN_ID=
MONDAY_ENQUIRY_TYPE_COLUMN_ID=
MONDAY_MESSAGE_COLUMN_ID=
MONDAY_SOURCE_COLUMN_ID=
MONDAY_SUBMITTED_DATE_COLUMN_ID=

# Public canonical site URL used for metadata, sitemap, robots, and social previews.
NEXT_PUBLIC_SITE_URL=https://papaipay.my
